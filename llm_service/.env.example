# LLM API Keys (按需配置，至少配一个 DEEPSEEK_API_KEY 才能跑 Agent)
DEEPSEEK_API_KEY=
KIMI_API_KEY=
QWEN_API_KEY=

# LLM 端点（OpenAI 兼容协议）
DEEPSEEK_BASE_URL=https://api.deepseek.com
KIMI_BASE_URL=https://api.moonshot.cn/v1
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek V4 模型（2026-04 发布，1M context）
# - V4 Pro  = 1.6T 总参 / 49B 激活，强推理，适合 Agent 复杂任务
# - V4 Flash= 284B 总参 / 13B 激活，速度快、价格低，适合高频调用
DEEPSEEK_DEEP_MODEL=deepseek-v4-pro       # 替代旧 deepseek-reasoner（R1）
DEEPSEEK_FAST_MODEL=deepseek-v4-flash     # 替代旧 deepseek-chat（V3）
DEEPSEEK_LONG_MODEL=deepseek-v4-pro       # 1M context 足够，V4 Pro 充当长文档

# Embedding
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# RAG
CHROMA_PERSIST_DIR=./.chroma
RAG_TOP_K=10
RAG_RERANK_TOP_K=5

# 服务
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
